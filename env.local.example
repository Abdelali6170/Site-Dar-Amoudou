# .env.local — Dar Amoudou

# ── Sanity ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=u46mu3xu
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=mytoken1_value  # Remplace par la vraie valeur

# ── Visual Editing / Draft Mode ───────────────────────────────────────────────
# Génère une chaîne aléatoire 32 chars : openssl rand -base64 32
SANITY_PREVIEW_SECRET=REMPLACE_PAR_32_CHARS_ALEATOIRES

# ── URLs ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ton-domaine-hostinger.com
# En dev, ne pas définir NEXT_PUBLIC_SITE_URL → localhost:3000 utilisé par défaut
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
